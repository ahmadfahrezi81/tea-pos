{
    "compilerOptions": {
        "target": "ES2017",
        "lib": ["dom", "dom.iterable", "esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "paths": {
            "@tea-pos/ui/*": ["./packages/ui/*"],
            "@tea-pos/db/*": ["./packages/db/*"],
            "@tea-pos/features/*": ["./packages/features/*"],
            "@tea-pos/services/*": ["./packages/services/*"],
            "@tea-pos/utils/*": ["./packages/utils/*"],
        },
    },
    "include": [
        "packages/**/*.ts",
        "packages/**/*.tsx",
        "apps/**/*.ts",
        "apps/**/*.tsx",
    ],
    "exclude": ["node_modules", "**/node_modules", "**/.next"],
}
